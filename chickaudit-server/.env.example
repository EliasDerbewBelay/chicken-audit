# Copy to .env and fill in your values

# PostgreSQL connection string
# Local:    postgres://postgres:password@localhost:5432/chickaudit
# Railway:  provided automatically as $DATABASE_URL
DATABASE_URL=postgres://postgres:password@localhost:5432/chickaudit

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# Token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=4000

# Allowed frontend origin (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# Starting flock count — adjust if you add or remove birds
STARTING_FLOCK=200
