# Copy to .env and fill in your values

# PostgreSQL connection string
# Local:    postgres://postgres:password@localhost:5432/chickaudit
# Supabase: copy "URI" from Project Settings → Database (Session pooler recommended)
#   Direct:   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#   Pooler:   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# If your password contains special characters (@, #, /, etc.), URL-encode it.
DATABASE_URL=postgres://postgres:password@localhost:5432/chickaudit

# JWT secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# Token expiry
JWT_EXPIRES_IN=7d

# Server port
PORT=4000

# Allowed frontend origin(s), comma-separated (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000

# Starting flock count — adjust if you add or remove birds
STARTING_FLOCK=200

# development | production
NODE_ENV=development

# Run migrations on startup (default: true in development, false in production)
AUTO_MIGRATE=false

# Seed users when the users table is empty (default: false)
AUTO_SEED=false

# Optional database pool tuning
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECT_TIMEOUT_MS=10000
